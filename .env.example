# ── Database ───────────────────────────────────────────────
# Local example: postgres://USER:PASSWORD@localhost:5432/rewardsdesk
# Railway injects DATABASE_URL automatically when a Postgres plugin is attached.
DATABASE_URL=postgres://localhost:5432/rewardsdesk

# Force TLS for the DB connection. Leave unset for local dev and Railway's
# internal network; set to "true" for most external managed Postgres.
# PGSSL=true

# ── Auth ───────────────────────────────────────────────────
# Use a long random value in production, e.g. `openssl rand -base64 48`.
JWT_SECRET=dev-change-me-to-a-long-random-string

# ── Initial admin (consumed by `npm run seed`) ─────────────
ADMIN_NAME=Hotel Owner
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=change-me-now

# ── Runtime ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Dev only: the Vite origin allowed by CORS.
CLIENT_ORIGIN=http://localhost:5173

# Prod only: domain for the auth cookie (e.g. rewardsdesk.up.railway.app).
# COOKIE_DOMAIN=
